# SmartTour · .env
# Configurazione sicura — NON committare questo file su Git!
# Aggiungi .env al file .gitignore
# ═══════════════════════════════════════════════════════════════════

# Chiave API Anthropic (Claude)
# Ottieni la tua chiave da: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-... # Inserisci qui la tua chiave API

# Porta del server (di default 3000)
PORT=3000

# Node environment
NODE_ENV=development
